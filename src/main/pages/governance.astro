import Default from '../layouts/Default.astro';

const title = 'Governance | TARIDE Foundation';
const description = 'TARIDE is a Dutch non-profit foundation. Board, funding, and conflict-of-interest principles.';
---

<Default title={title} description={description} pageId="governance">
  <div class="container-reading">

    <span class="page-eyebrow">TARIDE Foundation</span>
    <h1 class="page-title">Governance</h1>
    <p class="page-lede">
      TARIDE is a Dutch non-profit foundation (Stichting TARIDE), registered with the Chamber of Commerce in Amsterdam under KvK 42061504. The foundation does not currently hold ANBI status; donations are therefore not tax-deductible in the Netherlands.
    </p>

    <h2>Board</h2>

    <article class="bio">
      <span class="role">Chairperson</span>
      <h3>Martin Voorzanger</h3>
      <p>M.Sc., Delft University of Technology. Over thirty years in technology with a focus on go-to-market and product development, including roles at Lost Boys Interactive (an EU project on MPEG-4, among others), TomTom (navigation), and EclecticIQ (cybersecurity). Founder of Toogethr, a Dutch carpool and rideshare platform, and a ten-year contributor to Ethereum-based projects.</p>
    </article>

    <article class="bio">
      <span class="role">Secretary</span>
      <h3>Leonard Wolters</h3>
      <p>M.Sc. in Artificial Intelligence, University of Amsterdam. Over twenty-five years in technology with a focus on engineering, data science, and technology entrepreneurship. Co-founder of SmartHaven (smart search), JTeam (enterprise software), SpringSource (enterprise open-source), Victor Platform (blockchain foundation), and Crobox (consumer psychology).</p>
    </article>

    <article class="bio">
      <span class="role">Open seat</span>
      <h3>Third board seat</h3>
      <p>One seat is currently open. The foundation is seeking a third board member with complementary background in policy, cryptography, or institutional governance. Expressions of interest: <a href="mailto:info@taride.org">info@taride.org</a>.</p>
    </article>

    <h2>Funding</h2>
    <p>
      The foundation operates on a combination of grants, public funding, and individual donations. It receives no commercial revenue and accepts no commercial sponsorship that would create a conflict of interest with the protocol's neutrality.
    </p>

    <h2>Conflict of interest</h2>
    <p>
      Board members disclose material affiliations relevant to the foundation's work. Funding sources that would tie the foundation's positions to commercial or political interests are declined.
    </p>

  </div>
</Default>

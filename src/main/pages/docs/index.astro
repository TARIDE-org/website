---
import { getCollection } from 'astro:content';
import Default from '../../layouts/Default.astro';
import Search from '../../components/Search.astro';

const docs = (await getCollection('docs')).sort((a, b) => a.data.order - b.data.order);

const blurbs = {
  foundation: 'The protocol overview, design constraints, and intended scope.',
  telecom: 'Integration with telecom providers and the credential lifecycle.',
  'threat-model': 'Security threats considered and the attack taxonomy.',
  privacy: 'GDPR considerations and identifier handling.',
  technical: 'DID methods, credential formats, resolver architecture.',
};

const version = docs[0]?.data.version ?? 'v0.51';
const lastUpdated = docs[0]?.data.lastUpdated ?? '';

const title = 'Specifications | TARIDE';
const description = 'The TARIDE foundation document and four supporting briefs: telecom, threat model, privacy analysis, technical summary.';
---

<Default title={title} description={description} pageId="docs">
  <div class="container-reading">

    <span class="page-eyebrow">TARIDE Foundation</span>
    <h1 class="page-title">Specifications</h1>
    <p class="page-lede">
      The foundation document and the four supporting briefs that develop it. All are work in progress and open to targeted review.
    </p>

    <Search />

    <nav class="routes" aria-label="Specification documents">
      {docs.map((d, i) => (
        <a class="route" href={`/docs/${d.id}/`}>
          <span class="num">§ {String(i + 1).padStart(2, '0')}</span>
          <div class="body">
            <h2>{d.data.title}</h2>
            <p>{blurbs[d.id] ?? ''}</p>
          </div>
          <span class="arrow" aria-hidden="true">→</span>
        </a>
      ))}
    </nav>

    <p class="status">
      Foundation document {version}. Last updated {lastUpdated}.
    </p>

  </div>
</Default>

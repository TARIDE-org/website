// Pagefind search over the spec docs. The index is generated at build time
// (after astro build) into /pagefind/. The init script is an external
// 'self' file (public/scripts/docs-search.js) rather than an inline script,
// so it runs under the site's strict CSP without 'unsafe-inline'.
---
<div id="docs-search" class="docs-search"></div>
<link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
<script is:inline src="/scripts/docs-search.js" defer></script>
